# Focus Hub Frontend - Environment Variables
# Copy this file to .env and fill in the values

# API URL (for production, set to your backend URL)
VITE_API_URL=http://localhost:5000/api

# For production, example:
# VITE_API_URL=https://focus-hub-api.onrender.com/api

# Gemini API Key (for FoxIA Assistant)
GEMINI_API_KEY=your_gemini_api_key_here
